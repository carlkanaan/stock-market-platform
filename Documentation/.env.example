PORT=3000 # NestJs server port

MONGO_URI= # MongoDB Atlas connection string

JWT_SECRET= # JWT token key

JWT_EXPIRES_IN=1d # JWT expiration 

OTP_TTL_MINUTES=10 # OTP expiration duration (min)

SENDGRID_API_KEY= # SendGrid API key for transactional emails

EMAIL_FROM= # Verified sender email used by SendGrid

THROTTLE_TTL_SECONDS=60 # Rate limit time window in seconds

THROTTLE_LIMIT=10 # Maximum number of requests allowed per TTL window

REDIS_HOST=localhost # Redis host

REDIS_PORT=6379 # Redis port

CACHE_TTL_SECONDS=60 # Default cache time-to-live in seconds

STRIPE_SECRET_KEY= # Stripe secret test key

STRIPE_WEBHOOK_SECRET= # Stripe webhook signing secret

STRIPE_SUCCESS_URL=http://localhost:3000/success

STRIPE_CANCEL_URL=http://localhost:3000/cancel

RABBITMQ_URL=amqp://localhost:5672 # RabbitMQ connection URL

RABBITMQ_NOTIFICATION_QUEUE=notifications_queue # Queue used for notification events