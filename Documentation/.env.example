PORT=3000 # NestJs server port

MONGO_URI= # MongoDB Atlas connection string

JWT_SECRET= # JWT token key

JWT_EXPIRES_IN=1d # JWT expiration 

OTP_TTL_MINUTES=10 # OTP expiration duration (min)

SENDGRID_API_KEY= # SendGrid API key for transactional emails

EMAIL_FROM= # Verified sender email used by SendGrid

THROTTLE_TTL_SECONDS=60 # Rate limit time window in seconds

THROTTLE_LIMIT=10 # Maximum number of requests allowed per TTL window